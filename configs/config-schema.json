{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "pipeline": {
      "type": "object",
      "properties": {
        "retryPreset": {
          "type": "string",
          "enum": ["default", "testing", "subscription"]
        },
        "maxConcurrentPipelines": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        }
      },
      "additionalProperties": false
    },
    "providers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["openai", "nvidia"]
      }
    }
  },
  "additionalProperties": true
}
