{
  "name": "demumumind-ultra-testings",
  "version": "0.1.0",
  "description": "Windows-first all-in-one AppSec platform for white-box testing of web applications and APIs.",
  "private": false,
  "license": "MIT",
  "homepage": "https://github.com/DemumuMind/demumumind-ultra-testings#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/DemumuMind/demumumind-ultra-testings.git"
  },
  "bugs": {
    "url": "https://github.com/DemumuMind/demumumind-ultra-testings/issues"
  },
  "keywords": [
    "appsec",
    "security-testing",
    "pentesting",
    "white-box",
    "windows",
    "typescript",
    "api-security",
    "web-security"
  ],
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "build": "pnpm -r build",
    "cli": "node ./apps/cli/dist/index.js",
    "cli:dev": "pnpm --filter @shannon/cli dev",
    "dev:server": "pnpm --filter @shannon/server dev",
    "dev:daemon": "pnpm --filter @shannon/server dev",
    "dev:worker": "pnpm --filter @shannon/worker dev",
    "dev:web": "pnpm --filter @shannon/web dev",
    "dev:desktop": "pnpm --filter @shannon/desktop dev",
    "doctor": "node ./apps/cli/dist/index.js doctor",
    "package:desktop": "powershell -ExecutionPolicy Bypass -File ./scripts/windows/package-desktop.ps1",
    "package:win": "powershell -ExecutionPolicy Bypass -File ./scripts/windows/package-desktop.ps1",
    "temporal:server": "docker compose up temporal -d",
    "temporal:worker": "pnpm --filter @shannon/worker dev worker",
    "temporal:down": "docker compose down",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@shannon/cli": "workspace:*",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
